# Only compiled JS in out/ ships in the VSIX. This extension has zero runtime
# dependencies, so node_modules is excluded entirely (vsce strips devDeps anyway).
src/**
**/*.ts
**/*.map
node_modules/**

# Tooling & config not needed at runtime
.vscode/**
.vscode-test/**
.github/**
.temp/**
scripts/**
.gitignore
.vscodeignore
tsconfig.json
package-lock.json
CLAUDE.md
ROADMAP.md
TESTING.md

# Terminal/CLI front-ends — not part of the VS Code extension package.
out/cli.js
out/render-tty.js
out/config.js
out/live.js
extension/**
docs/**

# Build artifacts
*.vsix
